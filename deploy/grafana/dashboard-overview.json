{
  "dashboard": {
    "title": "Chess404 Service Overview",
    "uid": "chess404-overview",
    "tags": ["chess404", "overview"],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{service}} {{method}} {{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "HTTP Latency (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
            "legendFormat": "{{service}} {{method}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Active WebSocket Connections",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "ws_connections_active",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Active Matches",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "matches_active",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Match Creation Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rate(matches_created_total[5m])",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Queue Depth",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "queue_depth",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "In-Flight Requests",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "http_requests_in_flight",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
            "legendFormat": "{{service}} {{method}}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
