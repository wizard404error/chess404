{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "gateway": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/gateway.Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/readyz",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "resources": {
          "cpu": 1,
          "memory": 512
        }
      }
    },
    "match-service": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/match-service.Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/readyz",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "resources": {
          "cpu": 1,
          "memory": 1024
        }
      }
    },
    "platform-service": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/platform-service.Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/readyz",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "variables": {
          "MATCH_CLAIM_STORE_BACKEND": "redis",
          "MATCH_CLAIM_STORE_REDIS_URL": "${{Redis.REDIS_URL}}"
        },
        "resources": {
          "cpu": 1,
          "memory": 512
        }
      }
    },
    "matchmaking-service": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/matchmaking-service.Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/readyz",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "variables": {
          "MATCHMAKING_TICKET_STORE_BACKEND": "redis",
          "MATCHMAKING_TICKET_STORE_REDIS_URL": "${{Redis.REDIS_URL}}"
        },
        "resources": {
          "cpu": 0.5,
          "memory": 256
        }
      }
    },
    "analysis-worker": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/Dockerfile.analysis-worker"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "resources": {
          "cpu": 1,
          "memory": 1024
        }
      }
    },
    "web": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "deploy/railway/web.Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "resources": {
          "cpu": 1,
          "memory": 512
        }
      }
    }
  },
  "volumes": {
    "platform-data": {
      "mountPath": "/app/data",
      "service": "platform-service"
    },
    "match-archives": {
      "mountPath": "/app/archives",
      "service": "platform-service"
    }
  }
}
